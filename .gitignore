# Python virtual environments
.venv/
venv/
env/

# Nested virtual environments in sub-projects
**/.venv/
**/venv/
**/env/

# Environment variable files
.env
.env.*
**/.env
**/.env.*
# ...but always allow committing example/template env files
!.env.example
!**/.env.example

# Python cache/artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
dist/
build/

# IDE/system files
.DS_Store
Thumbs.db
.vscode/
.idea/

# ChromaDB persisted local data (generated at runtime)
**/chroma_db/
**/chroma.sqlite3
**/*.sqlite3
**/*.sqlite3-shm
**/*.sqlite3-wal
