# LangSmith tracing (optional)
# Set LANGSMITH_TRACING=true and provide an API key to view traces in LangSmith.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="assistant-v2-tools"

# OpenAI (only required if config/settings.py uses the OpenAI embeddings provider).
# Leave blank when running fully on Ollama.
OPENAI_API_KEY=
